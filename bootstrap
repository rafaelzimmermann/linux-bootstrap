#!/bin/bash

set -ex

source "$(dirname "$0")/lib/pkg.sh"

# Ask for sudo once and keep the credential alive for the duration of the script
sudo -v
while true; do sudo -v; sleep 50; done &
SUDO_KEEPALIVE=$!
trap "kill $SUDO_KEEPALIVE 2>/dev/null || true" EXIT

pkg_update

case "$OS" in
    arch)
        pkg_install vim htop tmux git python-pip ruby samba jq curl zsh inetutils
        bash "$(dirname "$0")/install/install-yay"
        bash "$(dirname "$0")/config/config-nvidia"
        bash "$(dirname "$0")/config/config-hyprland"
        ;;
    *)
        pkg_install vim htop tmux git python3-pip ruby-full samba jq curl zsh
        ;;
esac

chsh -s /bin/zsh

bash "$(dirname "$0")/install/install-ohmyzsh"
bash "$(dirname "$0")/install/install-rust"
bash "$(dirname "$0")/config/config-python"
bash "$(dirname "$0")/config/config-tmux"
bash "$(dirname "$0")/install/install-java"
bash "$(dirname "$0")/install/install-nerdfonts"
bash "$(dirname "$0")/install/install-nvim"

cp -r "$(dirname "$0")/config/assets/dotconfig/." "${HOME}/.config"
